{
    "name": "t2-backend",
    "version": "1.0.0",
    "description": "T2 E-commerce Backend API",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon --watch src --exec ts-node src/index.ts",
        "build": "prisma generate && prisma db push --accept-data-loss && tsc",
        "start": "node dist/index.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:push": "prisma db push",
        "prisma:seed": "ts-node prisma/seed.ts",
        "seed:admin": "ts-node scripts/create_super_admin.ts",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "keywords": [
        "ecommerce",
        "api",
        "backend"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.3.5",
        "@types/nodemailer": "^7.0.11",
        "@types/nodemon": "^1.19.6",
        "@types/uuid": "^10.0.0",
        "axios": "^1.13.5",
        "axios-cookiejar-support": "^6.0.5",
        "bcryptjs": "^2.4.3",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.1",
        "prisma": "^5.22.0",
        "tough-cookie": "^6.0.0",
        "typescript": "^5.9.3",
        "uuid": "^11.0.5",
        "winston": "^3.18.0",
        "xss": "^1.0.15",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2"
    },
    "overrides": {
        "prisma": "^5.22.0",
        "@prisma/client": "^5.22.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}